# Copy to `.streamlit/secrets.toml` for local Streamlit (never commit real secrets).

# Required on Streamlit Cloud unless you commit data/pois.db (not recommended)
# Optional — app downloads from the public release below if unset
POI_DB_DOWNLOAD_URL = "https://github.com/dheerajmw/AITripPlannerForDelhiNCR/releases/download/v0.1.0-poi/pois.db"

# Optional — AI tips per stop
GROQ_API_KEY = "gsk_..."
GROQ_MODEL = "llama-3.3-70b-versatile"

# OSRM (default works on macOS with http)
OSRM_BASE_URL = "http://router.project-osrm.org"
