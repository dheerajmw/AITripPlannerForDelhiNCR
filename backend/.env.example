# Backend environment (copy to backend/.env)
# Never commit .env with real secrets.

DEBUG=false
# Leave empty to use <repo>/data/pois.db
DATABASE_URL=

# Required for browser → API when not using Next.js proxy
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

OVERPASS_API_URL=https://overpass-api.de/api/interpreter
OVERPASS_TIMEOUT_SEC=90
OVERPASS_MAX_RETRIES=3
CORS_ORIGINS=http://localhost:3000

# OSRM (Phase 2)
# Public demo: http avoids TLS handshake issues with macOS system Python (LibreSSL).
OSRM_BASE_URL=http://router.project-osrm.org

# Groq (Phase 4) — server-side only
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SEC=25
